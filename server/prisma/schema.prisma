// ============================================================
// Prisma Schema for School Management Platform (SMP)
// Database: MySQL 9.7
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ──────────────────────────────────────────────────

/// User roles within the platform
enum Role {
  ADMIN
  TEACHER
  PARENT
}

/// Possible attendance statuses for a student on a given day
enum AttendanceStatus {
  PRESENT
  ABSENT
}

// ─── Models ─────────────────────────────────────────────────

/// Central authentication entity.
/// auth_identifier stores the login credential:
///   - email for ADMIN
///   - emp_id for TEACHER
///   - mobile number for PARENT
model User {
  id                 Int       @id @default(autoincrement())
  role               Role
  auth_identifier    String    @unique
  password_hash      String?   // nullable — parents authenticate via OTP (now password)
  mustChangePassword Boolean   @default(true) @map("must_change_password")
  resetCode          String?   @unique @map("reset_code")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  // Relations
  teacher  Teacher?   // A TEACHER user has exactly one Teacher profile
  students Student[]  // A PARENT user owns zero-or-more students

  @@map("users")
}

/// Student record, linked to a parent User via parentMobile.
model Student {
  id           Int      @id @default(autoincrement())
  name         String
  className    String   @map("class_name")
  parentMobile String   @map("parent_mobile")

  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  parent     User         @relation(fields: [parentMobile], references: [auth_identifier])
  attendance Attendance[]
  marks      Mark[]

  @@map("students")
}

/// Teacher profile, 1-to-1 with a User of role TEACHER.
model Teacher {
  id                 Int                 @id @default(autoincrement())
  userId             Int                 @unique @map("user_id")
  name               String
  empId              String              @unique @map("emp_id")
  phone              String?             @unique @map("phone_number")
  mustChangePassword Boolean             @default(true) @map("must_change_password")
  resetCode          String?             @unique @map("reset_code")

  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  user        User                @relation(fields: [userId], references: [id])
  assignments TeacherAssignment[]
  marks       Mark[]
  homeworks   Homework[]

  @@map("teachers")
}

/// Academic subject (e.g. Mathematics, Science).
model Subject {
  id   Int    @id @default(autoincrement())
  name String @unique

  // Relations
  assignments TeacherAssignment[]
  marks       Mark[]
  homeworks   Homework[]

  @@map("subjects")
}

/// A school class/section (e.g. "10-A", "9-B").
/// Managed independently so admins can pre-create classes
/// before students are enrolled.
model Class {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  createdAt DateTime @default(now()) @map("created_at")

  @@map("classes")
}

/// Maps a teacher to a class + subject combination.
/// A teacher can teach multiple subjects across multiple classes.
model TeacherAssignment {
  id        Int      @id @default(autoincrement())
  teacherId Int      @map("teacher_id")
  className String   @map("class_name")
  subjectId Int?     @map("subject_id")
  role      String   @default("SUBJECT_TEACHER") @map("role") // "CLASS_TEACHER" or "SUBJECT_TEACHER"

  // Relations
  teacher Teacher  @relation(fields: [teacherId], references: [id])
  subject Subject? @relation(fields: [subjectId], references: [id])

  // A teacher cannot be assigned the same subject in the same class twice
  @@unique([teacherId, className, subjectId])
  @@map("teacher_assignments")
}

/// Daily attendance record for a student.
model Attendance {
  id        Int              @id @default(autoincrement())
  studentId Int              @map("student_id")
  date      DateTime
  status    AttendanceStatus

  // Relations
  student Student @relation(fields: [studentId], references: [id])

  // One attendance entry per student per day
  @@unique([studentId, date])
  @@map("attendance")
}

/// Exam marks for a student in a specific subject, graded by a teacher.
model Mark {
  id        Int    @id @default(autoincrement())
  studentId Int    @map("student_id")
  subjectId Int    @map("subject_id")
  teacherId Int    @map("teacher_id")
  score     Float
  maxScore  Float  @default(100) @map("max_score")
  examName  String @map("exam_name")
  internalScore Float? @map("internal_score")
  theoryScore   Float? @map("theory_score")

  // Relations
  student Student @relation(fields: [studentId], references: [id])
  subject Subject @relation(fields: [subjectId], references: [id])
  teacher Teacher @relation(fields: [teacherId], references: [id])

  // A student can only have one mark per subject per exam
  @@unique([studentId, subjectId, examName])
  @@map("marks")
}

// ─── Announcement Models ──────────────────────────────────────

enum Audience {
  TEACHER
  PARENT
  BOTH
}

model Announcement {
  id        Int      @id @default(autoincrement())
  title     String
  content   String   @db.Text
  target    Audience
  createdAt DateTime @default(now()) @map("created_at")

  @@map("announcements")
}

model Homework {
  id          Int      @id @default(autoincrement())
  className   String   @map("class_name")
  subjectId   Int      @map("subject_id")
  teacherId   Int      @map("teacher_id")
  title       String
  description String   @db.Text
  dueDate     DateTime @map("due_date")
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  subject Subject @relation(fields: [subjectId], references: [id])
  teacher Teacher @relation(fields: [teacherId], references: [id])

  @@map("homework")
}
